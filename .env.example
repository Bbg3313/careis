# 사이트 공개 URL (토스 success/fail URL·웹훅 생성 시 사용)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 토스페이먼츠 — https://developers.tosspayments.com/my/api-keys
# 결제창 연동: API 개별 연동 키의 클라이언트 키(test_ck_… / live_ck_…)
NEXT_PUBLIC_TOSS_CLIENT_KEY=
# 서버에서만 사용. 절대 클라이언트에 노출하지 마세요.
TOSS_SECRET_KEY=
# 또는 아래 이름으로 동일 값 설정 가능
# TOSS_PAYMENTS_SECRET_KEY=

# 명시적으로 PG 라벨을 고정할 때만 사용 (미설정 시 키가 있으면 자동으로 TOSS_PAYMENTS)
# PG_PROVIDER=TOSS_PAYMENTS
