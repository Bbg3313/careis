# 사이트 공개 URL (토스 success/fail·웹훅 URL 생성 시 사용). Vercel 등 배포 시 실제 도메인과 동일하게 설정.
# 예: https://your-domain.vercel.app  (끝 슬래시 없이)
# 로컬: http://localhost:3000  — 주문 생성 시 success/fail 이 주소 기준으로 저장됩니다.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Prisma — PostgreSQL 필수 (로컬·Vercel 동일). Supabase 를 쓰는 경우 Auth 프로젝트와 같은 DB 를 쓰면 됩니다.
# Dashboard > Project Settings > Database > Connection string > URI
# 호스트는 보통 db.<project-ref>.supabase.co 포트 5432. 비밀번호에 @ 등이 있으면 URL 인코딩하세요.
# 예: postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true
# 마이그레이션까지 단순히 맞추려면 Direct connection(5432) URI 를 권장합니다.
DATABASE_URL=

# --- 토스페이먼츠 (PG 심사·테스트 결제) ---
# 가이드: https://developers.tosspayments.com/  → 상점 관리자 로그인 → 개발자 센터 → API 키 → 테스트 키
# 문서: https://docs.tosspayments.com/reference/using-api/api-keys
#
# 1) NEXT_PUBLIC_TOSS_CLIENT_KEY : 브라우저 번들용(선택). test_ck_ 또는 live_ck_.
# 2) TOSS_CLIENT_KEY : 서버에서 동일 클라이언트 키를 런타임에 읽기 위한 값(Vercel에서 NEXT_PUBLIC만 있을 때
#    빌드에 비어 박히는 경우 대비). 비우면 NEXT_PUBLIC_TOSS_CLIENT_KEY만 사용합니다.
# 3) TOSS_SECRET_KEY : 서버 승인(/api/payments/confirm) 전용. test_sk_ 또는 live_sk_ (절대 프론트에 넣지 마세요).
#    동일 이름 대신 TOSS_PAYMENTS_SECRET_KEY 로 넣어도 됩니다.
# 클라이언트 키만 있어도 결제창은 열리며, 시크릿이 있어야 결제 완료 후 주문이 "결제 완료"로 반영됩니다.
# 리다이렉트 URL: 토스 콘솔에 {SITE_URL}/payment/return , {SITE_URL}/payment/fail 형태가 허용되도록 등록하세요.
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
# 또는 아래 이름으로 동일 값 설정 가능
# TOSS_PAYMENTS_SECRET_KEY=

# 명시적으로 PG 라벨을 고정할 때만 사용 (미설정 시 키가 있으면 자동으로 TOSS_PAYMENTS)
# PG_PROVIDER=TOSS_PAYMENTS

# Supabase (관리자 로그인) — Dashboard > Project Settings > API
# Project URL 전체, anon 키는 보통 eyJ 로 시작하는 JWT
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 위 이름 대신 아래만 넣어도 서버에서 동일하게 인식합니다 (값은 위와 같아야 함).
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# 운영 전 권장: 허용할 관리자 이메일만 (쉼표 구분). 비우면 Supabase 로그인만 되면 /admin 접근 가능
# ADMIN_ALLOWED_EMAILS=you@company.com,coworker@company.com
#
# Supabase 콘솔에서 할 일: Authentication > Providers > Email 켜기
# 관리자 계정: Authentication > Users 에서 이메일 사용자 추가 후 비밀번호 설정
# 로그인만 테스트할 때: Authentication > Providers > Email > Confirm email 끄기(선택)
#
# 상품 상세 이미지 업로드(Vercel 필수): Dashboard > Project Settings > API > service_role 키 (절대 프론트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=
# Storage > New bucket → 이름 정확히 product-detail → Public bucket 으로 생성
