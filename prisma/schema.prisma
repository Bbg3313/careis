generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  NAVER_PAY
  TOSS_PAY
  KAKAO_PAY
}

model Product {
  id           String        @id @default(cuid())
  sku          String        @unique
  slug         String        @unique
  name         String
  shortName    String
  tagline      String
  description  String
  price        Int
  thumbnailUrl String?
  status       ProductStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  orderItems   OrderItem[]
}

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique
  customerName   String
  phone          String
  address        String
  postalCode     String
  memo           String?
  totalAmount    Int
  paymentStatus  OrderStatus   @default(PENDING)
  paymentMethod  PaymentMethod
  paymentProvider String?
  paymentReference String?
  paymentToken    String?
  paymentRequestedAt DateTime?
  paidAt          DateTime?
  cancelledAt     DateTime?
  refundedAt      DateTime?
  paymentFailureCode String?
  paymentFailureMessage String?
  paymentPayload  String?
  referralCode   String?
  couponCode     String?
  /** 택배사명 (자유 입력) */
  carrier            String?
  /** 운송장 번호 */
  trackingNumber     String?
  shippedAt          DateTime?
  /** 관리자 메모 (고객 비노출) */
  adminNote          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  orderItems     OrderItem[]
}

model OrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  productId           String
  sku                 String
  productNameSnapshot String
  quantity            Int
  unitPrice           Int
  createdAt           DateTime @default(now())
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product  @relation(fields: [productId], references: [id])
}

/** 관리자 업로드 상품 상세 스토리 컷 (선팩 등 세로 스크롤 영역) */
model ProductDetailSlide {
  id          String   @id @default(cuid())
  productSlug String
  sortOrder   Int
  url         String
  width       Int
  height      Int
  mimeType    String
  posterUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productSlug, sortOrder])
}
