generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

/** 결제 완료(PAID) 이후 물류 단계. 미결제·취소·환불 주문은 null */
enum FulfillmentStatus {
  AWAITING_SHIP
  IN_TRANSIT
  DELIVERED
}

enum PaymentMethod {
  CREDIT_CARD
  NAVER_PAY
  TOSS_PAY
  KAKAO_PAY
}

enum PromoDiscountType {
  PERCENT
  FIXED_PER_UNIT
}

model Product {
  id           String        @id @default(cuid())
  sku          String        @unique
  slug         String        @unique
  name         String
  shortName    String
  tagline      String
  description  String
  price        Int
  thumbnailUrl String?
  status       ProductStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  orderItems   OrderItem[]
}

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique
  customerName   String
  phone          String
  address        String
  postalCode     String
  memo           String?
  totalAmount    Int
  paymentStatus  OrderStatus   @default(PENDING)
  paymentMethod  PaymentMethod
  paymentProvider String?
  paymentReference String?
  paymentToken    String?
  paymentRequestedAt DateTime?
  paidAt          DateTime?
  cancelledAt     DateTime?
  refundedAt      DateTime?
  paymentFailureCode String?
  paymentFailureMessage String?
  paymentPayload  String?
  referralCode   String?
  couponCode     String?
  /** 주문 시점에 적용된 공구/프로모 캠페인 코드(정규화). 미적용 시 null */
  appliedPromoCode String?
  /** 택배사명 (자유 입력) */
  carrier            String?
  /** 운송장 번호 */
  trackingNumber     String?
  /** 스마트택배(스윗트래커) 택배사 코드 — API 자동 배송완료에 사용 */
  trackingCarrierCode  String?
  shippedAt          DateTime?
  /** 결제 완료 후 배송 진행 단계 (미결제 등은 null) */
  fulfillmentStatus FulfillmentStatus?
  /** 관리자가 배송완료 처리한 시각 */
  deliveredAt       DateTime?
  /** 관리자 메모 (고객 비노출) */
  adminNote          String?
  /** 스마트택배 조회 마지막 시각 (조회 한도·부하 완화) */
  lastSweetTrackerPollAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  orderItems     OrderItem[]
}

/** 인플루 공구 등: 코드(?ref= / 쿠폰)와 기간·할인 규칙 */
model PromoCampaign {
  id             String            @id @default(cuid())
  code           String            @unique
  /// 쇼핑몰 상단 공구 타이머에 노출되는 문구(관리자 「상단바 표시」)
  title          String
  discountType   PromoDiscountType
  discountValue  Int
  productSlugs   Json
  startsAt       DateTime
  endsAt         DateTime
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model OrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  productId           String
  sku                 String
  productNameSnapshot String
  quantity            Int
  unitPrice           Int
  createdAt           DateTime @default(now())
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product  @relation(fields: [productId], references: [id])
}

/** 관리자 업로드 상품 상세 스토리 컷 (선팩 등 세로 스크롤 영역) */
model ProductDetailSlide {
  id          String   @id @default(cuid())
  productSlug String
  sortOrder   Int
  url         String
  width       Int
  height      Int
  mimeType    String
  posterUrl   String?
  /** 제품상세 스토리: 이미지 아래 노출. 빈 줄(\\n\\n)로 문단 구분 */
  body        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productSlug, sortOrder])
}
