generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  NAVER_PAY
  TOSS_PAY
  KAKAO_PAY
}

model Product {
  id           String        @id @default(cuid())
  sku          String        @unique
  slug         String        @unique
  name         String
  shortName    String
  tagline      String
  description  String
  price        Int
  thumbnailUrl String?
  status       ProductStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  orderItems   OrderItem[]
}

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique
  customerName   String
  phone          String
  address        String
  postalCode     String
  memo           String?
  totalAmount    Int
  paymentStatus  OrderStatus   @default(PENDING)
  paymentMethod  PaymentMethod
  referralCode   String?
  couponCode     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  orderItems     OrderItem[]
}

model OrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  productId           String
  sku                 String
  productNameSnapshot String
  quantity            Int
  unitPrice           Int
  createdAt           DateTime @default(now())
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product  @relation(fields: [productId], references: [id])
}
